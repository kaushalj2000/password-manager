{
  "manifest_version": 3,
  "name": "PocketVault Autofill",
  "version": "1.0.0",
  "description": "Connects to the PocketVault desktop app and autofills website logins.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:37654/*"
  ],
  "action": {
    "default_title": "PocketVault Autofill",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
