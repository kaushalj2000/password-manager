{
  "name": "pocketvault-desktop",
  "version": "1.4.0",
  "description": "PocketVault desktop app with an encrypted sync-friendly vault file.",
  "author": "OpenAI Codex",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --dir",
    "build": "electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^37.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.codex.passwordmanager",
    "productName": "PocketVault",
    "artifactName": "PocketVault-Setup-${version}.${ext}",
    "files": [
      "index.html",
      "styles.css",
      "script.js",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    },
    "publish": {
      "provider": "github",
      "owner": "kaushalj2000",
      "repo": "password-manager"
    }
  }
}
